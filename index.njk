---
layout: base.njk
---

{% for section in collections.sections %}
    {% if section.data.order == 1 %}
        <!-- HERO SECTION -->
        <section id="section-{{ section.data.order }}" class="relative pt-20 pb-12 lg:pt-24 lg:pb-16 flex flex-col items-center min-h-[90vh] lg:min-h-screen isolate">
            <!-- Premium Background: Abstract Rings (Fixed for Professional Theme) -->
            <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
                 <div class="absolute inset-0 flex items-center justify-end overflow-hidden opacity-30">
                     <div class="absolute w-[800px] h-[800px] right-[-10%] rounded-full border border-theme-text/20 flex items-center justify-center">
                         <div class="w-[600px] h-[600px] rounded-full border border-theme-text/20 flex items-center justify-center">
                             <div class="w-[400px] h-[400px] rounded-full border border-theme-text/20"></div>
                         </div>
                     </div>
                 </div>
                 
                 <!-- Subtle Gradient Glow -->
                 <div class="absolute inset-0 bg-gradient-to-tr from-theme-accent/5 via-transparent to-transparent opacity-50"></div>
                 
                 <!-- Fade out gradient at bottom -->
                 <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-theme-bg to-transparent pointer-events-none z-10"></div>
            </div>

            <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-20 w-full">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
                    
                    <!-- Left Column: Hero Text -->
                    <div class="lg:col-span-7 text-center lg:text-left">
                        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-theme-surface border border-theme-accent/30 text-theme-accent text-sm font-semibold mb-8 shadow-sm backdrop-blur-md">
                            <span class="relative flex h-2.5 w-2.5">
                              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-theme-accent opacity-75"></span>
                              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-theme-accent"></span>
                            </span>
                            {{ site.hero.badge }}
                        </div>
                        
                        <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight mb-8 leading-[1.1] text-theme-text drop-shadow-sm">
                            {{ section.data.title }}
                        </h1>
                        
                        <p class="mt-4 text-xl md:text-2xl text-theme-muted max-w-2xl mx-auto lg:mx-0 font-light mb-12 leading-relaxed">
                            {{ section.data.subtitle }}
                        </p>
                        
                        <div class="mt-8 flex flex-col sm:flex-row gap-5 justify-center lg:justify-start">
                            {% if section.data.cta_primary_link %}
                            <a href="{{ section.data.cta_primary_link }}" class="group relative inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-[var(--radius-theme)] text-theme-accent-fg bg-theme-accent overflow-hidden transition-all shadow-lg hover:shadow-theme-accent/40 hover:-translate-y-1 ring-1 ring-black/10">
                                <span class="absolute w-0 h-0 transition-all duration-500 ease-out bg-white rounded-full group-hover:w-56 group-hover:h-56 opacity-10"></span>
                                <span class="relative flex items-center gap-2">
                                    {{ section.data.cta_primary_text }}
                                    <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                    </svg>
                                </span>
                            </a>
                            {% endif %}

                            {% if section.data.cta_secondary_link %}
                            <a href="{{ section.data.cta_secondary_link }}" class="inline-flex items-center justify-center px-8 py-4 border border-theme-text/10 text-base font-semibold rounded-[var(--radius-theme)] text-theme-text bg-white/5 backdrop-blur-md hover:bg-theme-surface transition-all hover:border-theme-text/20 hover:-translate-y-1 shadow-sm">
                                {{ section.data.cta_secondary_text }}
                            </a>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Right Column: Visual Book Card -->
                    <div class="lg:col-span-4 lg:col-start-9 hidden lg:block relative group perspective-1000">
                        <div class="absolute -inset-1 rounded-[calc(var(--radius-theme)+0.5rem)] bg-gradient-to-r from-theme-accent to-blue-500 opacity-20 group-hover:opacity-40 blur transition duration-500"></div>
                        <a href="https://book.cdif.org" target="_blank" class="relative block bg-theme-surface/80 backdrop-blur-xl border border-theme-text/10 rounded-[var(--radius-theme)] p-8 shadow-2xl transition-all duration-500 transform group-hover:-translate-y-2 group-hover:scale-[1.02] group-hover:rotate-y-2 group-hover:border-theme-accent/50">
                            
                            <!-- Book Graphic / Icon container -->
                            <div class="h-48 w-full bg-theme-text/5 rounded flex items-center justify-center mb-6 relative overflow-hidden">
                                <div class="absolute inset-0 bg-gradient-to-br from-theme-accent/10 to-transparent"></div>
                                <div class="relative z-10 bg-white/95 backdrop-blur-md shadow-xl border border-white/20 rounded-xl p-5 group-hover:shadow-theme-accent/20 transition-all duration-300 transform group-hover:-translate-y-1">
                                    <img src="/assets/images/cdif+480-transparent.png" alt="CDIF Book Logo" class="w-auto h-16 object-contain drop-shadow-sm">
                                </div>
                            </div>
                            
                            <div>
                                <div class="text-xs font-bold uppercase tracking-widest text-theme-accent mb-2">{{ site.hero.bookCard.prefix }}</div>
                                <h3 class="text-2xl font-bold text-theme-text mb-2 leading-tight">{{ site.hero.bookCard.title }}</h3>
                                <p class="text-sm text-theme-muted mb-6">{{ site.hero.bookCard.description }}</p>
                                
                                <div class="inline-flex items-center text-sm font-semibold text-theme-text group-hover:text-theme-accent transition-colors">
                                    {{ site.hero.bookCard.cta }}
                                    <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                                    </svg>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- NEWS TICKER INTEGRATED INTO HERO -->
                <div id="news-ticker" class="w-full mt-14 lg:mt-20 mb-8 lg:mb-12 scroll-mt-32">
                    <div class="bg-theme-surface/30 backdrop-blur-md py-4 border border-theme-text/10 overflow-hidden whitespace-nowrap relative shadow-md">
                        <div class="absolute inset-0 z-10 pointer-events-none flex justify-between">
                            <div class="h-full w-12 bg-gradient-to-r from-theme-bg/20 to-transparent"></div>
                            <div class="h-full w-12 bg-gradient-to-l from-theme-bg/20 to-transparent"></div>
                        </div>
                        
                        <div class="flex items-center h-full">
                            <div class="flex-shrink-0 bg-theme-accent text-theme-accent-fg px-4 py-1 text-[10px] font-bold uppercase tracking-widest z-20 ml-4 shadow-sm">
                                Latest
                            </div>
                            
                            <div class="relative overflow-hidden flex-grow px-4">
                                <div class="flex animate-ticker whitespace-nowrap hover:[animation-play-state:paused]">
                                    {% for item in news %}
                                    <div class="inline-flex items-center px-6">
                                        <span class="text-xs font-medium text-theme-muted mr-3">{{ item.date }}</span>
                                        <span class="text-[9px] font-bold uppercase tracking-wider text-theme-accent opacity-60 mr-2">[{{ item.type }}]</span>
                                        <a href="/news-events/#{{ item.id }}" class="text-sm font-semibold text-theme-text hover:text-theme-accent transition-colors">
                                            {{ item.title }}
                                        </a>
                                    </div>
                                    {% endfor %}
                                    
                                    <!-- Duplicate for seamless loop -->
                                    {% for item in news %}
                                    <div class="inline-flex items-center px-6">
                                        <span class="text-xs font-medium text-theme-muted mr-3">{{ item.date }}</span>
                                        <span class="text-[9px] font-bold uppercase tracking-wider text-theme-accent opacity-60 mr-2">[{{ item.type }}]</span>
                                        <a href="/news-events/#{{ item.id }}" class="text-sm font-semibold text-theme-text hover:text-theme-accent transition-colors">
                                            {{ item.title }}
                                        </a>
                                    </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <style>
            @keyframes ticker {
                0% { transform: translateX(0); }
                100% { transform: translateX(-50%); }
            }
            .animate-ticker {
                animation: ticker 15s linear infinite;
            }
        </style>

    {% else %}
        <!-- STANDARD SECTION -->
        <section id="section-{{ section.data.order }}" class="py-12 lg:py-16 relative scroll-mt-24 {% if loop.index % 2 == 0 %}bg-theme-surface/50{% endif %}">
            <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-start">
                    
                    <!-- Section Title Sidebar -->
                    <div class="lg:w-1/3 lg:sticky lg:top-32 pt-2">
                        <h2 class="text-3xl md:text-4xl lg:text-4xl font-bold mb-4 text-theme-text leading-tight tracking-tight">
                            {{ section.data.title }}
                        </h2>
                        <div class="h-1.5 w-16 bg-theme-accent rounded-full opacity-80"></div>
                    </div>
                    
                    <!-- Content Area -->
                    <div class="lg:w-2/3 w-full">
                        <div class="prose prose-lg md:prose-xl max-w-none 
                                    text-theme-text/90 
                                    prose-a:text-theme-accent prose-a:font-semibold prose-a:no-underline prose-a:hover:underline prose-a:underline-offset-4
                                    prose-headings:text-theme-text prose-headings:font-bold prose-headings:tracking-tight
                                    prose-strong:text-theme-text prose-strong:font-bold
                                    prose-li:text-theme-text/90 prose-li:marker:text-theme-accent
                                    prose-p:leading-relaxed prose-p:mb-6 prose-p:text-inherit
                                    prose-ul:bg-theme-surface prose-ul:rounded-[var(--radius-theme)] prose-ul:p-6 prose-ul:shadow-sm prose-ul:border prose-ul:border-theme-text/5">
                            {{ section.content | safe }}
                        </div>
                    </div>
                    
                </div>
            </div>
        </section>
    {% endif %}
{% endfor %}
