---
layout: base.njk
---
<div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="prose prose-lg md:prose-xl max-w-none 
                text-theme-text/90 
                prose-a:text-theme-accent prose-a:font-semibold prose-a:no-underline hover:prose-a:underline prose-a:underline-offset-4
                prose-headings:text-theme-text prose-headings:font-bold prose-headings:tracking-tight
                prose-strong:text-theme-text prose-strong:font-bold
                prose-li:text-theme-text/90 prose-li:marker:text-theme-accent
                prose-p:leading-relaxed prose-p:mb-6 prose-p:text-inherit
                prose-ul:bg-theme-surface prose-ul:rounded-[var(--radius-theme)] prose-ul:p-6 prose-ul:shadow-sm prose-ul:border prose-ul:border-theme-text/5">
        {{ content | safe }}
    </div>
</div>
