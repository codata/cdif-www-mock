<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default(site.name + " - " + site.fullName) }}</title>
    <meta name="description" content="{{ site.tagline }}">
    
    <!-- Open Graph & Twitter Meta Tags for Reviewer Link Sharing -->
    <meta property="og:title" content="{{ site.name }} - {{ site.fullName }}">
    <meta property="og:description" content="{{ site.tagline }} Prototype staging site.">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://cdif.codata.org/assets/images/cdif+480-transparent.png">
    <meta name="twitter:card" content="summary_large_image">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Alpine JS Plugins -->
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/persist@3.14.8/dist/cdn.min.js"></script>
    <!-- Alpine JS Core -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
    
    <!-- Custom Tailwind Styles -->
    <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body x-data="{ theme: $persist('light'), menuOpen: false }" :data-theme="theme" class="antialiased min-h-screen flex flex-col transition-colors duration-300">
    
    <!-- Header Navigation -->
    <header class="sticky top-0 z-50 w-full glass shadow-sm transition-all duration-300">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex h-20 items-center justify-between">
                <!-- Logo -->
                <div class="flex-shrink-0 group">
                    <a href="/" class="flex items-center gap-3 relative">
                        <div class="absolute inset-0 bg-white/40 blur-[16px] rounded-full scale-110 pointer-events-none transition-opacity duration-300 group-hover:bg-white/60"></div>
                        <img class="relative z-10 h-10 w-auto transition-transform duration-300 group-hover:scale-105" src="/assets/images/cdif+300-transparent.png" alt="{{ site.name }} Logo">
                    </a>
                </div>
                
                <!-- Desktop nav -->
                <div class="hidden md:block">
                    <div class="ml-10 flex items-baseline space-x-6">
                        {% for section in collections.sections %}
                            {% if section.data.title and section.data.order > 1 %}
                            <a href="/#section-{{ section.data.order }}" class="text-theme-muted hover:text-theme-accent transition-colors duration-200 px-3 py-2 text-sm font-semibold tracking-tight uppercase">
                                {{ section.data.nav_title | default(section.data.title) }}
                            </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <!-- Light/Dark Toggle -->
                    <button @click="theme = (theme === 'light' ? 'dark' : 'light')" 
                            class="p-2 rounded-full hover:bg-theme-surface transition-colors focus:outline-none border border-theme-text/10"
                            :title="theme === 'light' ? 'Switch to Dark Mode' : 'Switch to Light Mode'">
                        <!-- Sun Icon -->
                        <svg x-show="theme === 'dark'" class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707.707M12 5a7 7 0 100 14 7 7 0 000-14z"></path></svg>
                        <!-- Moon Icon -->
                        <svg x-show="theme === 'light'" class="w-5 h-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                    </button>

                    <!-- Mobile menu button -->
                    <div class="-mr-2 flex md:hidden">
                        <button @click="menuOpen = !menuOpen" type="button" class="inline-flex items-center justify-center rounded-md p-2 hover:bg-theme-surface hover:text-theme-accent focus:outline-none">
                            <span class="sr-only">Open main menu</span>
                            <svg class="h-6 w-6" x-show="!menuOpen" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                            </svg>
                            <svg class="h-6 w-6" x-show="menuOpen" style="display: none;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Mobile Menu panel -->
        <div x-show="menuOpen" class="md:hidden glass border-t border-gray-200">
            <div class="space-y-1 px-2 pb-3 pt-2 sm:px-3">
                 {% for section in collections.sections %}
                    {% if section.data.title and section.data.order > 1 %}
                    <a href="/#section-{{ section.data.order }}" @click="menuOpen = false" class="block rounded-md px-3 py-2 text-base font-semibold tracking-tight uppercase hover:bg-theme-accent hover:text-white">{{ section.data.nav_title | default(section.data.title) }}</a>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
        {{ content | safe }}
    </main>

    <!-- Footer -->
    <footer class="bg-theme-surface py-12 border-t border-theme-accent/10 mt-20">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div class="col-span-1 md:col-span-2">
                    <img class="h-12 w-auto mb-6 opacity-90 hover:opacity-100 transition-opacity" src="/assets/images/cdif+300-transparent.png" alt="{{ site.name }} Logo">
                    <p class="text-sm text-theme-muted max-w-sm leading-relaxed mb-4">{{ site.footer.description }}</p>
                    <p class="text-sm font-semibold text-theme-text opacity-90">{{ site.footer.attribution | safe }}</p>
                </div>
                <div>
                    <h3 class="text-sm font-semibold uppercase tracking-wider text-theme-text opacity-70">Framework</h3>
                    <ul class="mt-4 space-y-2">
                        {% for link in site.footer.links.framework %}
                        <li><a href="{{ link.url }}" class="text-sm text-theme-muted hover:text-theme-accent transition-colors">{{ link.text }}</a></li>
                        {% endfor %}
                    </ul>
                </div>
                <div>
                    <h3 class="text-sm font-semibold uppercase tracking-wider text-theme-text opacity-70">Resources</h3>
                    <ul class="mt-4 space-y-2">
                        {% for link in site.footer.links.resources %}
                        <li><a href="{{ link.url }}" {% if link.external %}target="_blank" rel="noopener noreferrer"{% endif %} class="text-sm text-theme-muted hover:text-theme-accent transition-colors {% if link.bold %}font-semibold{% endif %}">{{ link.text }}</a></li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
            <div class="mt-12 border-t border-theme-text/10 pt-8 flex justify-between items-center">
                <p class="text-sm text-theme-muted">{{ site.footer.copyright | safe }}</p>
            </div>
        </div>
    </footer>

    <!-- Fixed Floating Feedback Button -->
    <a href="https://github.com/codata/cdif-www-mock/issues" target="_blank" class="fixed bottom-6 right-6 z-50 group flex items-center justify-center gap-2 px-5 py-3 rounded-full bg-theme-surface/70 backdrop-blur-xl border border-theme-accent/20 text-sm font-semibold text-theme-text shadow-xl hover:shadow-theme-accent/20 hover:bg-theme-accent hover:text-white hover:border-theme-accent transition-all duration-300 transform hover:-translate-y-1">
        <span class="relative flex h-2 w-2 mr-1">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-theme-accent opacity-75 group-hover:bg-white drop-shadow-md"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-theme-accent group-hover:bg-white"></span>
        </span>
        Feedback
        <svg class="w-4 h-4 ml-1 opacity-70 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
    </a>

</body>
</html>
