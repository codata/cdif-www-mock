---
layout: base.njk
title: Latest News & Events
pagination:
  data: sortedNews
  size: 9
  alias: pagedNews
permalink: "news-events/{% if pagination.pageNumber > 0 %}{{ pagination.pageNumber + 1 }}/{% endif %}index.html"
---

<div class="py-24 bg-theme-bg">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mb-16">
            <h1 class="text-4xl font-bold tracking-tight text-theme-text sm:text-5xl mb-6">{{ site.pages.news.title }}</h1>
            <p class="text-xl text-theme-muted leading-relaxed">
                {{ site.pages.news.lead }}
            </p>
        </div>

        <style>
            @keyframes highlight-pulse {
                0% { 
                    border-color: color-mix(in srgb, var(--color-theme-accent), transparent 20%);
                    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-theme-accent), transparent 80%);
                    transform: translateY(-8px);
                }
                50% {
                    border-color: color-mix(in srgb, var(--color-theme-accent), transparent 20%);
                    box-shadow: 0 0 25px 0 color-mix(in srgb, var(--color-theme-accent), transparent 70%);
                }
                100% { 
                    border-color: color-mix(in srgb, var(--color-theme-text), transparent 95%);
                    box-shadow: none;
                    transform: translateY(0);
                }
            }
            article:target {
                animation: highlight-pulse 3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
                z-index: 10;
            }
        </style>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for item in pagedNews %}
            <article id="{{ item.id }}" class="flex flex-col bg-theme-surface/50 border border-theme-text/5 rounded-xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 scroll-mt-32 relative">
                <div class="p-8 flex-grow">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider 
                            {% if item.type == 'event' %}bg-blue-100 text-blue-700
                            {% elif item.type == 'publication' %}bg-purple-100 text-purple-700
                            {% else %}bg-green-100 text-green-700{% endif %}">
                            {{ item.type }}
                        </span>
                        <time class="text-xs text-theme-muted">{{ item.date }}</time>
                    </div>
                    <h2 class="text-xl font-bold text-theme-text mb-4 leading-tight">
                        <a href="{{ item.link }}" target="_blank" rel="noopener noreferrer" class="hover:text-theme-accent transition-colors">{{ item.title }}</a>
                    </h2>
                    <p class="text-theme-muted text-sm leading-relaxed mb-6">{{ item.summary }}</p>
                    
                    <div class="flex flex-wrap gap-2 mt-auto">
                        {% for tag in item.tags %}
                        <span class="text-[10px] text-theme-muted px-2 py-0.5 bg-theme-text/5 rounded">#{{ tag }}</span>
                        {% endfor %}
                    </div>
                </div>
                <div class="px-8 pb-8">
                    <a href="{{ item.link }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-semibold text-theme-accent hover:underline decoration-2 underline-offset-4">
                        Learn More
                        <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    </a>
                </div>
            </article>
            {% endfor %}
        </div>

        <!-- Pagination Controls -->
        {% if pagination.pages.length > 1 %}
        <nav class="mt-20 flex items-center justify-between border-t border-theme-text/10 px-4 sm:px-0 pt-10">
            <div class="-mt-px flex w-0 flex-1">
                {% if pagination.href.previous %}
                <a href="{{ pagination.href.previous }}" class="inline-flex items-center border-t-2 border-transparent pr-1 pt-4 text-sm font-medium text-theme-muted hover:border-theme-accent hover:text-theme-text transition-all">
                    <svg class="mr-3 h-5 w-5 text-theme-muted" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M18 10a.75.75 0 01-.75.75H4.66l2.1 1.95a.75.75 0 11-1.02 1.1l-3.5-3.25a.75.75 0 010-1.1l3.5-3.25a.75.75 0 111.02 1.1l-2.1 1.95h12.59A.75.75 0 0118 10z" clip-rule="evenodd" />
                    </svg>
                    Previous
                </a>
                {% endif %}
            </div>
            
            <div class="hidden md:-mt-px md:flex">
                {% for pageEntry in pagination.pages %}
                {% set pageNumber = loop.index %}
                <a href="{{ pagination.hrefs[loop.index0] }}" 
                   class="inline-flex items-center border-t-2 px-4 pt-4 text-sm font-medium transition-all
                   {% if pagination.pageNumber == (pageNumber - 1) %}border-theme-accent text-theme-accent{% else %}border-transparent text-theme-muted hover:border-theme-text/20 hover:text-theme-text{% endif %}"
                   {% if pagination.pageNumber == (pageNumber - 1) %}aria-current="page"{% endif %}>
                    {{ pageNumber }}
                </a>
                {% endfor %}
            </div>

            <div class="-mt-px flex w-0 flex-1 justify-end">
                {% if pagination.href.next %}
                <a href="{{ pagination.href.next }}" class="inline-flex items-center border-t-2 border-transparent pl-1 pt-4 text-sm font-medium text-theme-muted hover:border-theme-accent hover:text-theme-text transition-all">
                    Next
                    <svg class="ml-3 h-5 w-5 text-theme-muted" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M2 10a.75.75 0 01.75-.75h12.59l-2.1-1.95a.75.75 0 111.02-1.1l3.5 3.25a.75.75 0 010 1.1l-3.5 3.25a.75.75 0 11-1.02-1.1l2.1-1.95H2.75A.75.75 0 012 10z" clip-rule="evenodd" />
                    </svg>
                </a>
                {% endif %}
            </div>
        </nav>
        {% endif %}
    </div>
</div>
